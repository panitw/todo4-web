# Backend API URL — read by the Next.js server at startup (runtime, not build time)
API_URL=http://localhost:3000
# MCP server URL — proxied via /mcp route for AI agent connections
MCP_URL=http://localhost:3002
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_GIT_SHA=
# Performance tracing sample rate (0.0-1.0, default 0.2 prod / 1.0 staging)
# NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.2
# SENTRY_AUTH_TOKEN=  # CI-only — required for source map uploads
# SENTRY_ORG=         # CI-only — Sentry organization slug
# SENTRY_PROJECT=     # CI-only — Sentry project slug
